{
  "name": "@nimbusnexus/docs",
  "version": "0.1.0",
  "private": false,
  "description": "Source of truth for https://nimbusnexus.net/docs — concept pages and API reference, in Markdown.",
  "license": "CC-BY-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NimbusNexus/docs.git"
  },
  "homepage": "https://nimbusnexus.net/docs",
  "bugs": {
    "url": "https://github.com/NimbusNexus/docs/issues"
  },
  "scripts": {
    "lint": "npm run lint:markdown && npm run lint:frontmatter && npm run lint:placeholders && npm run lint:templates && npm run lint:links",
    "lint:markdown": "markdownlint-cli2 'content/**/*.md'",
    "lint:frontmatter": "node scripts/validate-frontmatter.mjs",
    "lint:placeholders": "node scripts/validate-placeholders.mjs",
    "lint:templates": "node scripts/validate-no-template-markers.mjs",
    "lint:links": "lychee --no-progress --offline 'content/**/*.md' || true"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "markdownlint-cli2": "^0.22.1",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24"
  }
}
